{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "firebase-debug.log",
      "product-readme.md",
      "CLAUDE.md",
      "README.md"
    ],
    "redirects": [
      { "source": "/terms.html", "destination": "/terms", "type": 301 },
      { "source": "/privacy.html", "destination": "/privacy", "type": 301 }
    ],
    "rewrites": [
      { "source": "/terms", "destination": "/terms/index.html" },
      { "source": "/privacy", "destination": "/privacy/index.html" }
    ],
    "headers": [
      {
        "source": "**/*.@(html)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(css|js|png|jpg|jpeg|svg|webp|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
