{
  "hosting": {
    "public": ".",
    "cleanUrls": true,
    "trailingSlash": false,
    "ignore": [
      "firebase.json",
      ".firebaserc",
      ".git/**",
      ".github/**",
      ".claude/**",
      "**/.gitignore",
      "**/node_modules/**",
      "firebase-debug.log",
      "product-readme.md",
      "CLAUDE.md",
      "README.md"
    ],
    "redirects": [
      { "source": "/terms.html", "destination": "/terms", "type": 301 },
      { "source": "/privacy.html", "destination": "/privacy", "type": 301 }
    ],
    "rewrites": [
      { "source": "/terms", "destination": "/terms/index.html" },
      { "source": "/privacy", "destination": "/privacy/index.html" }
    ],
    "headers": [
      {
        "source": "/",
        "headers": [
          {
            "key": "Link",
            "value": "</.well-known/api-catalog>; rel=\"api-catalog\", </.well-known/mcp/server-card.json>; rel=\"describedby\" type=\"application/json\", </index.md>; rel=\"alternate\" type=\"text/markdown\""
          }
        ]
      },
      {
        "source": "/.well-known/api-catalog",
        "headers": [
          { "key": "Content-Type", "value": "application/linkset+json" },
          { "key": "Access-Control-Allow-Origin", "value": "*" }
        ]
      },
      {
        "source": "/.well-known/mcp/server-card.json",
        "headers": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Access-Control-Allow-Origin", "value": "*" }
        ]
      },
      {
        "source": "/.well-known/agent-skills/index.json",
        "headers": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Access-Control-Allow-Origin", "value": "*" }
        ]
      },
      {
        "source": "/index.md",
        "headers": [
          { "key": "Content-Type", "value": "text/markdown; charset=utf-8" },
          { "key": "Access-Control-Allow-Origin", "value": "*" }
        ]
      },
      {
        "source": "**/*.@(html)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
        ]
      },
      {
        "source": "**/*.@(css|js|png|jpg|jpeg|svg|webp|woff2)",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ]
  }
}
